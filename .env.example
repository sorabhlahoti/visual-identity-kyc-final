# Copy to .env before production-like testing.
# Local hackathon demo defaults use mock embeddings to avoid heavy model download.
# For real biometric embeddings set EMBEDDING_MODE=arcface and download the ONNX model.

EMBEDDING_MODE=mock
LIVENESS_REQUIRED=false
AUTH_REQUIRED=false
HASH_PEPPER=replace-with-a-long-random-secret-at-least-32-chars
JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-chars
DID_ISSUER=did:web:localhost

# Optional thresholds
FACE_DUP_THRESHOLD=0.82
FACE_MATCH_THRESHOLD=0.80
NAME_MATCH_THRESHOLD=0.70
PARTIAL_FACE_THRESHOLD=0.72
TOP_K=8

# Kafka REST proxy resilience for slower Windows/Docker startup
KAFKA_PUBLISH_TIMEOUT_SEC=30
KAFKA_PUBLISH_RETRIES=6

# UI / browser access. Use * for local demo, or comma-separated origins for stricter deploy.
CORS_ALLOWED_ORIGINS=*
